//Q7: Write a program that takes a string of alphabets (in character array) from the user
//(assuming there are no white spaces entered) and then convert all the alphabets into lower or upper case without using any built in function.


#include<iostream>
using namespace std;
void capital(char q[], int x);
void small(char q[], int x);


int main()
{
	char q[200];

	cout << "Write a word without spaces" << endl;
	cin >> q;

	cout << endl << endl;

	cout << "In capital letters" << endl;
	capital(q,200);
	cout << endl;
	
	cout << "In small letters" << endl;
	small(q,200);
}
void capital(char q[],int x)
{
	int i = 0;
	while (q[i] != '\0')
	{
		if (q[i] > 96 && q[i] < 123)
			q[i] -= 32;
		i++;
	}
	cout << q << endl;

}

void small(char q[],int x)
{
	int f = 0;
	
	while (q[f] != '\0')
	{
		if (q[f] <= 90 && q[f] >= 65)
			q[f] += 32;
		f++;
	}
	cout << q << endl;
}
