//Q3: Write a program that takes a string of characters (in character array) from the user (including white spaces) and then asks a single character from user. You have to count how many times that single character appears in array.
// Checking letter repitition.cpp

#include <iostream>
using namespace std;

void fnc(char *c,int a)
{
	int x = 0;
	char b;
	cout << "Enter the letter" << endl;
	cin >> b;

	for (int i = 0; i < a; i++)
	{
		if (c[i] == b)
			x++;
	}

	cout << x;
}

int main()
{
	char c[2000];
	cout << "Enter the text" << endl;
	cin.getline(c, 2000);
	
	int a = 0;
	while (c[a] != 0)
		a++;
	
	fnc(c, a);
}
