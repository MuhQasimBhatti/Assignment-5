//Q2: Write a program that takes a string of characters (in character array) from the user (including white spaces) and then tells the user how many doubles (when two similar (not three) character appears at contiguous location) in the array.


// Checking contiguous doubles.cpp : This file contains the 'main' function. Program execution begins and ends there.
//

//Q 2
#include <iostream>
using namespace std;

int fnc(char a[], int x)
{
	int i = 0;
	int j = 0;
	int c = 0;

	while (a[i] != '\0')
	{
		i++;
	}

	while (j < i)
	{
		if (a[j] == a[j + 1] && a[j] != a[j + 2] && a[j] != a[j - 1])
		{
			c++;
		}
		j++;
	}
	return c;
}

int main()
{
	char a[200];
	cout << "Enter the text" << endl;
	cin.getline(a, 200);

	cout << fnc(a,200);
}
