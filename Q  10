//Q10: Write a program that reads a character and an integer n from user and prints entered character n times.
// printing a character n times.cpp 

#include<iostream>
using namespace std;

void fnc(char a,int i)
{
	for (int x = 1; x <= i; x++)
		cout << a << endl;
}

int main() 
{
	char a;
	int i;
	cout << "Enter character" << endl;
	cin >> a;
	cout << "How many time it should display?" << endl;
	cin >> i;

	fnc(a, i);

}
