//Q6: Write a program that takes a string of characters (in character array) from the user (including white spaces) and then tells the user how many tripples (when three similar (not four) character appears at contiguous location) in the array.
// Checking contigous triples.cpp : This file contains the 'main' function. Program execution begins and ends there.


#include <iostream>
using namespace std;

int main()
{
	char a[200];
	int x = 0;
	int i = 0;
	cout << "Enter a text" << endl;
	cin.getline(a, 200);

	while (a[i] != 0)
	{
		if (a[i] == a[i + 1] && a[i] == a[i + 2])
		{
			if (a[i] != a[i + 3] && a[i] != a[i - 1])
				x++;
		}
		i++;
	}
	cout << x << endl;

}
