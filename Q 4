/*Q4: Write a program that takes a string of characters (in character array) from the user (assuming there are no white spaces entered) and then tells the user how many characters are in the array.
Example:
Input: hellodearhowru
Output:9*/

#include<iostream>
using namespace std;
int main()
{
	char A[200];

	cout << "Enter a sentence" << endl;
	cin.getline(A, 200);
  int q = 0;
	while (A[q] != '\0')
		q++;
	cout << "No. of letters in the sentence are " << q << endl;
}
